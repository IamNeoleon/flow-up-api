generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

model User {
   id                  String              @id @default(uuid())
   email               String              @unique
   isEmailVerified     Boolean             @default(false)
   username            String              @unique
   fullName            String
   password            String?
   avatar              String?
   workspace           Workspace[]
   workspaceMembers    WorkspaceMember[]
   createdAt           DateTime            @default(now())
   updatedAt           DateTime            @updatedAt
   tasks               Task[]
   boardMembers        BoardMembers[]
   boards              Board[]
   workspaceActivities WorkspaceActivity[]
   oauthAccounts       OAuthAccount[]
   authSessions        AuthSession[]
   taskComments        TaskComment[]
   notifications       Notification[]
   userRecentTasks     UserRecentTask[]
}

model VerificationCode {
   id        Int      @id @default(autoincrement())
   email     String   @unique
   code      String
   attempts  Int      @default(0)
   expiresAt DateTime
   createdAt DateTime @default(now())
}

model OAuthAccount {
   id String @id @default(uuid())

   provider          OAuthProvider
   providerAccountId String

   userId String
   user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

   email         String?
   emailVerified Boolean?

   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt

   @@unique([provider, providerAccountId])
   @@index([userId])
}

model AuthSession {
   id     String @id @default(uuid())
   userId String
   user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

   refreshTokenHash String
   createdAt        DateTime  @default(now())
   lastUsedAt       DateTime?
   expiresAt        DateTime
   revokedAt        DateTime?

   ip        String?
   userAgent String?

   @@index([userId])
   @@index([expiresAt])
}

model Workspace {
   id                  String              @id @default(uuid())
   name                String
   description         String?
   icon                String?
   isArchived          Boolean             @default(false)
   ownerId             String
   owner               User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
   boards              Board[]
   workspaceMembers    WorkspaceMember[]
   workspaceInvites    WorkspaceInvite[]
   createdAt           DateTime            @default(now())
   updatedAt           DateTime            @updatedAt
   workspaceActivities WorkspaceActivity[]
}

model WorkspaceMember {
   id          String         @id @default(uuid())
   role        WorkspaceRoles
   userId      String
   user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
   workspaceId String
   workspace   Workspace      @relation(fields: [workspaceId], references: [id])
   createdAt   DateTime       @default(now())

   @@unique([userId, workspaceId])
}

model WorkspaceInvite {
   id          String         @id @default(uuid())
   workspaceId String
   role        WorkspaceRoles
   expiresAt   DateTime
   createdAt   DateTime       @default(now())
   workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Board {
   id           String         @id @default(uuid())
   name         String
   description  String?
   imageUrl     String?
   workspaceId  String
   workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
   ownerId      String
   owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
   columns      Column[]
   createdAt    DateTime       @default(now())
   updatedAt    DateTime       @updatedAt
   boardMembers BoardMembers[]
}

model BoardMembers {
   id      String     @id @default(uuid())
   userId  String
   user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
   boardId String
   board   Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
   role    BoardRoles

   @@unique([userId, boardId])
}

model Column {
   id        String       @id @default(uuid())
   name      String
   order     Int
   status    ColumnStatus
   boardId   String
   board     Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
   tasks     Task[]
   color     String?
   createdAt DateTime     @default(now())
   updatedAt DateTime     @updatedAt
}

model Task {
   id              String           @id @default(uuid())
   name            String
   description     String?
   order           Int
   assigneeId      String?
   assignee        User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
   priorityId      String?
   priority        TaskPriorities?  @relation(fields: [priorityId], references: [id], onDelete: SetNull)
   colId           String
   column          Column           @relation(fields: [colId], references: [id], onDelete: Cascade)
   todos           TaskTodo[]
   attachments     TaskAttachment[]
   doneAt          DateTime?
   dueDate         DateTime?
   createdAt       DateTime         @default(now())
   updatedAt       DateTime         @updatedAt
   taskComments    TaskComment[]
   userRecentTasks UserRecentTask[]

   @@index([colId])
   @@index([assigneeId])
}

model TaskPriorities {
   id     String @id @default(uuid())
   name   String
   weight Int
   color  String
   tasks  Task[]
}

model TaskTodo {
   id        String   @id @default(uuid())
   title     String
   completed Boolean  @default(false)
   taskId    String
   task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
   createdAt DateTime @default(now())
}

model TaskComment {
   id       String @id @default(uuid())
   content  String
   taskId   String
   task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
   authorId String
   author   User   @relation(fields: [authorId], references: [id])

   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
}

model TaskAttachment {
   id        String           @id @default(uuid())
   filename  String
   key       String           @unique
   size      Int
   mimeType  String
   taskId    String
   status    AttachmentStatus
   task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
   createdAt DateTime         @default(now())
}

model WorkspaceActivity {
   id          String                @id @default(uuid())
   workspaceId String
   actorId     String
   type        WorkspaceActivityType
   entityId    String
   metadata    Json?
   createdAt   DateTime              @default(now())
   workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
   user        User                  @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model Notification {
   id        String           @id @default(uuid())
   userId    String
   user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
   type      NotificationType
   sourceId  String
   read      Boolean          @default(false)
   createdAt DateTime         @default(now())
   updatedAt DateTime         @updatedAt
   metadata  Json?

   @@index([userId, read])
   @@index([userId, id])
}

model UserRecentTask {
   id     String @id @default(uuid())
   userId String
   user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
   taskId String
   task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

   lastOpenedAt DateTime @default(now())

   @@unique([userId, taskId])
   @@index([userId, lastOpenedAt(sort: Desc)])
}

enum NotificationType {
   DEADLINE_SOON
   DEADLINE_OVERDUE
   STATUS_CHANGE
   ADD_ASSIGMENT
   REMOVE_ASSIGMENT
   COMMENT_MENTION
}

enum WorkspaceActivityType {
   TASK_ASSIGNED
   TASK_COMMENTED
   TASK_MOVED
   TASK_CREATED
   TASK_DELETED
   BOARD_CREATED
   COLUMN_CREATED
   USER_JOINED
   USER_LEFT
   COLUMN_DELETED
}

enum AttachmentStatus {
   PENDING
   READY
}

enum OAuthProvider {
   GOOGLE
   GITHUB
}

enum BoardRoles {
   EDITOR
   OWNER
}

enum WorkspaceRoles {
   MEMBER
   EDITOR
   OWNER
}

enum ColumnStatus {
   TODO
   IN_PROGRESS
   DONE
}
